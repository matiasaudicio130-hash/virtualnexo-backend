# ============================================================
# VIRTUALNEXO - Variables de Entorno (Backend)
# Copiar como .env y completar con valores reales
# ============================================================

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# JWT
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UN_STRING_LARGO_Y_ALEATORIO_256BITS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# MetaMap (KYC)
METAMAP_CLIENT_ID=tu-metamap-client-id
METAMAP_CLIENT_SECRET=tu-metamap-client-secret
METAMAP_FLOW_ID=tu-metamap-flow-id
METAMAP_WEBHOOK_SECRET=tu-metamap-webhook-secret
METAMAP_SIMULATION_MODE=true   # true en dev, false en prod

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
EMAIL_FROM_NAME=VirtualNexo
EMAIL_FROM_ADDRESS=noreply@virtualnexo.com

# Frontend URL (para links en emails)
FRONTEND_URL=http://localhost:5173

# Admin (primer admin del sistema)
ADMIN_MASTER_EMAIL=tu-email-admin@gmail.com

# CORS
CORS_ORIGINS=http://localhost:5173,https://tu-dominio.vercel.app
